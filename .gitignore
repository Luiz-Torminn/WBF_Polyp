\.env*

# Project outputs (results CSVs, predictions, visualizations).
.outputs/
.outputs*

# Python caches.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local model repositories are consumed as editable/local dependencies.
# Patterns intentionally drop the trailing slash so symlinks are ignored too.
DEIMv2
RFDETR
YOLO_model

# Large local checkpoints are required for execution but should not be committed.
pretrained_weights/

# Local agent/runtime artifacts.
.codex
.work_trees/

# Ignore local/per-machine Claude state (settings.local.json, etc.) but track
# the shared project rules under .claude/rules.
.claude/*
!.claude/rules/

# Worktree-only pointer file. Helps locate upstream repos when this branch
# is checked out as a git worktree (filesystem may forbid symlinks). Not
# needed when the pipeline runs from the merged main_working location
# where DEIMv2/, RFDETR/, YOLO_model/ are siblings of main.py.
.repo_root

# Common build, notebook, and packaging artifacts.
.ipynb_checkpoints/
build/
dist/
*.egg-info/

# Local docs scratch (mkdocs builds, etc.).
docs/
